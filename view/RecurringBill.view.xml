									<Text text="{JSBillList>Bukrs}" class="cl_column_cell"/>
								</uitable:template>
							</uitable:Column>
							<uitable:Column width="14%" hAlign="Center" class="cl_column_header">
								<Text text="{i18n>plant}" class="cl_Tltxt" tooltip="{i18n>plant}"/>
