				<VBox class="cl_materialdetails_header sapUiSmallMarginBottom">
    <HBox alignItems="Center">
        <Image src="Images/material_icon.png" class="cl_header_icon"/>
        <Text text="Material Details" class="cl_panel_title sapUiSmallMarginBegin"/>
    </HBox>
</VBox>

			<List id="id_polist" items="{JMItemdetPO>/}" class="cl_list">
	<CustomListItem>
		<VBox class="materialCard sapUiTinyMarginBottom">
			<Text text="{JMItemdetPO>Purchaseorder} / {JMItemdetPO>Ebelp}" class="materialHeader"/>
			
		
			
			<VBox>
				<HBox>
					<Text text="Material" class="labelText"/>
					<Text text=": " class="labelSeparator"/>
					<Text text="{JMItemdetPO>Potext} - {JMItemdetPO>Material}" class="valueText"/>
				</HBox>
				<HBox>
					<Text text="Tax Code" class="labelText"/>
					<Text text=": " class="labelSeparator"/>
					<Text text="{JMItemdetPO>Taxcode}" class="valueText"/>
				</HBox>
				<HBox>
					<Text text="Amount" class="labelText"/>
					<Text text=": " class="labelSeparator"/>
					<Text text="₹ {JMItemdetPO>Amount}" class="valueText"/>
				</HBox>
			</VBox>
		</VBox>
	</CustomListItem>
</List>

				<List id="id_nonpolist" items="{JMItemdet>/}" class="cl_list">
					<CustomListItem class="custom">
						<HBox class="cl_invvbox sapUiSmallMarginTop" alignContent="Center" alignItems="Center" justifyContent="Center">
							<Text text="{JMItemdet>Saknr} / {JMItemdet>Item}" class="cl_invtxt sapUiSmallMarginBegin"></Text>
						</HBox>
						<HBox width="100%">
							<VBox width="26%" class="sapUiSmallMarginBegin">
								<Text text="{i18n>profit}" class="cl_Apptext sapUiSmallMarginTop"></Text>
								<Text text="{i18n>cost}" class="cl_Apptext sapUiTinyMarginTop"></Text>
								<Text text="{i18n>currency}" class="cl_Apptext sapUiTinyMarginTop"></Text>
							</VBox>
							<VBox width="3%">
								<Text text="{i18n>:}" class="cl_Apptext sapUiSmallMarginTop"></Text>
								<Text text="{i18n>:}" class="cl_Apptext sapUiTinyMarginTop"></Text>
								<Text text="{i18n>:}" class="cl_Apptext sapUiTinyMarginTop"></Text>
							</VBox>
							<VBox width="37%">
								<Text text="{JMItemdet>Prctr}" class="cl_dashtxt sapUiSmallMarginTop"></Text>
								<Text text="{JMItemdet>Kostl}" class="cl_dashtxt sapUiTinyMarginTop"></Text>
								<Text text="{path: 'JMInvdet>/0/Waers'}" class="cl_dashtxt sapUiTinyMarginTop"></Text>
							</VBox>
							<VBox width="45%" class="cl_invvbox1 sapUiSmallMarginEnd" alignContent="End" alignItems="End" justifyContent="End">
								<HBox>
									<Text text="{i18n>tax}" class="cl_Apptext sapUiSmallMarginTop"></Text>
									<Text text="{JMItemdet>Mwskz}" class="cl_dashtxt sapUiSmallMarginTop"></Text>
								</HBox>
								<HBox>
									<Text text="{i18n>amount}" class="cl_Apptext sapUiMediumMarginTop"></Text>
									<Text text="Rs.{JMItemdet>Netpr}" class="cl_dashtxt sapUiTinyMarginBegin sapUiMediumMarginTop"></Text>
								</HBox>
							</VBox>
						</HBox>
					</CustomListItem>
				</List>
				<VBox class="cl_invvline sapUiSmallMarginTop"></VBox>
				<Text text="{i18n>comments}" class="cl_Apptext sapUiSmallMarginBegin sapUiSmallMarginTop"></Text>
				<List id="id_list" items="{JMInvComment>/}" class="cl_list sapUiSmallMarginTop">
					<CustomListItem class="custom">
						<HBox id="id_hbox" class="cl_invuservbox">
							<HBox width="69%" alignContent="Start" alignItems="Start" justifyContent="Start">
								<Image src="Images/User_dp2.png" class="cl_userima sapUiSmallMarginBegin sapUiSmallMarginTop"></Image>
								<VBox>
									<Text text="{JMInvComment>From}" class="cl_Apptext sapUiSmallMarginBegin sapUiSmallMarginTop"></Text>
									<Text text="{JMInvComment>Comment}" class="cl_Apptext sapUiSmallMarginBegin"></Text>
								</VBox>
							</HBox>
							<HBox width="28%" class="cl_invhbox sapUiLargeMarginTop" alignContent="End" alignItems="End" justifyContent="End">
								<Image src="Images/Time.png"></Image>
								<Text text="{JMInvComment>Time}" class="cl_dashtxt cl_space sapUiTinyMarginBegin sapUiTinyMarginBottom"></Text>
							</HBox>
						</HBox>
					</CustomListItem>
				</List>
			</VBox>
