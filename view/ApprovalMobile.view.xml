<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" controllerName="FSC360NEW.controller.ApprovalMobile"
	xmlns:html="http://www.w3.org/1999/xhtml">
	<Page title="Title" showHeader="false" showFooter="true">
		<content>
			<VBox class="cl_toolvbox">
				<HBox class="cl_gradient_bg" justifyContent="SpaceBetween" alignItems="Center">
					<HBox class="leftIcons" alignItems="Center" width="30%">
						<Image src="Images/Menu.svg" class="cl_arrima"/>
					</HBox>
					<HBox class="centerLogo" alignItems="Center" width="40%" justifyContent="Center">
						<Image src="Images/FSCNXT_logo.svg" class="cl_logo"/>
					</HBox>
					<HBox class="rightIcons" alignItems="Center" width="30%" justifyContent="End">
						<Image src="Images/input1.svg" class="team_image1"/>
					</HBox>
				</HBox>
				<VBox class="cl_search_container">
					<HBox class="customSearchBox" alignItems="Center" justifyContent="SpaceBetween" width="100%">
						<HBox alignItems="Center" class="searchLeft" width="100%">
							<Image src="Images/magnify.svg" class="searchIcon"/>
							<Input placeholder="Search" class="searchInput" showValueHelp="false" type="Text" width="100%"/>
						</HBox>
						<Text text="⌘ K" class="shortcutHint"/>
					</HBox>
				</VBox>
				<ScrollContainer vertical="true" class="scrollContainerFixedHeight" >
					<VBox class="list_box">
						<List items="{JMQidlist>/}" id="id_qidList" class="customList1">
							<CustomListItem press="fn_viewdet" type="Active">
								<HBox alignItems="Center" class="name1_box">
									<Image src="Images/account-circle.svg" class="name1_icon"/>
									<Text text="{JMQidlist>Name1}" class="name1_text"/>
								</HBox>
								<HBox class="listItemBox1" width="100%">
									<VBox width="60%">
										<HBox alignItems="Center" class="dateBox">
											<Image src="Images/invoice-ses.svg" class="iconImage"/>
											<Text text="{JMQidlist>Invno}" class="invoiceText"/>
										</HBox>
										<HBox alignItems="Center" class="dateBox">
											<Image src="Images/calendar-ses.svg" class="iconImage"/>
											<Text text="{path: 'JMQidlist>Scandate',formatter :'FSC360NEW.model.formatter.fnDate'}" class="dateText"/>
										</HBox>
									</VBox>
									<VBox width="40%">
										<HBox alignItems="Center">
											<Text text="" class=""/>
										</HBox>
										<HBox justifyContent="End">
											<Text text="{JMQidlist>Ntamt} {JMQidlist>Waers}" class="clamtap"/>
										</HBox>
									</VBox>
								</HBox>
							</CustomListItem>
						</List>
					</VBox>
				</ScrollContainer>
