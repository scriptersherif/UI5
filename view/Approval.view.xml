									type="Transparent"/>
								<Button icon="Images/approved_white.svg" text="Accept" visible="false" press="fn_acceptrejpress" id="id_reject" class="bluebtn"
									type="Transparent"/>
							</HBox>
						</HBox>
					</HBox>
				</content>
			</Page>
		</pages>
