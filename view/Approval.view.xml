										</uitable:template>
									</uitable:Column>
								</uitable:columns>
							</uitable:Table>
							<VBox class="cl_approv_invoice_cont sapUiSmallMarginTop" width="100%">
								<HBox class="headerBox2" justifyContent="" alignItems="Center">
									<Image src="Images/comment_black.svg" width="" class="cl_appr_account"/>
									<Text text="Comments and Approval Timeline" class="clamtap sapUiTinyMarginBegin"/>
								</HBox>
								<VBox class="comment_box">
									<List width="95%" items="{JMInvComment>/}" id="id_list" showSeparators="None">
