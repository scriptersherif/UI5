													<VBox class="cl_Vline_clr" visible="{JMInvComment>VBoxClr}"/>
													<VBox class="cl_Vline_white" visible="{JMInvComment>VBoxWhite}"/>
												</VBox>
												<VBox>
													<Text text="Commented" class="timelineTitle"/>
													<Text text="{JMInvComment>From}" class="cl_comment_txt"/>
													<Text text="{JMInvComment>Comment}" class="cl_comment_txt"/>
												</VBox>
											</HBox>
										</CustomListItem>
									</List>
								</VBox>
							</VBox>
							<HBox justifyContent="End" class="cl_post_btn_box">
