									</uitable:Column>
									<uitable:Column hAlign="Center" width="15%">
										<Text text="{i18n>Amount}" tooltip="{i18n>Amount}" class="cl_Tltxt"/>
										<uitable:template>
											<Text text="{JMItemdet>Netpr} {JMItemdet>Currency}" tooltip="{JMItemdet>Netpr}" press="fn_nav_to_wb" class="cl_table_det_text"
