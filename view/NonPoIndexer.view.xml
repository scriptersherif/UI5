							<uitable:Table 
							id="idItemsTable"
    selectionMode="None" 
    rows="{ItemsModel>/items}" 
    enableCellFilter="true" 
    visibleRowCount="5" 
    fixedLayout="false"
    class="cl_nonpoindexer_table cl_approval_table cl_tble cl_custom_table"
    ariaLabelledBy="title">

    <uitable:columns>
        <!-- Expense Type -->
        <uitable:Column hAlign="Center" width="7rem">
            <Text text="Expense Type" class="cl_Tltxt ml-1"/>
            <uitable:template>
                <Text text="{ItemsModel>Expty}" 
                      tooltip="{ItemsModel>Expty}" 
                      class="cl_table_det_text" 
                      wrapping="false"/>
            </uitable:template>
        </uitable:Column>

        <!-- G/L Account -->
        <uitable:Column hAlign="Center" width="6rem">
            <Text text="G/L Account" class="cl_Tltxt"/>
            <uitable:template>
                <Text text="{ItemsModel>Hkont}" 
                      tooltip="{ItemsModel>Hkont}" 
                      class="cl_table_det_text" 
                      wrapping="false"/>
            </uitable:template>
        </uitable:Column>

        <!-- Short Text -->
        <uitable:Column hAlign="Center" width="6rem">
            <Text text="Short Text" class="cl_Tltxt"/>
            <uitable:template>
                <Text text="{ItemsModel>KontoTxt}" 
                      tooltip="{ItemsModel>KontoTxt}" 
                      class="cl_table_det_text" 
                      wrapping="false"/>
            </uitable:template>
        </uitable:Column>

        <!-- Amount -->
        <uitable:Column hAlign="Center" width="5.5rem">
            <Text text="Amount" class="cl_Tltxt"/>
            <uitable:template>
                <Text text="{path:'ItemsModel>Wrbtr' , formatter :'FSC360NEW.model.formatter.fnAmount'}" 
                      tooltip="{ItemsModel>Wrbtr}" 
                      class="cl_table_det_text" 
                      wrapping="false"/>
            </uitable:template>
        </uitable:Column>

      

        <!-- Cost Center -->
        <uitable:Column hAlign="Center" width="6rem">
            <Text text="Cost Center" class="cl_Tltxt"/>
            <uitable:template>
                <Text text="{ItemsModel>Kostl}" 
                      tooltip="{ItemsModel>Kostl}" 
                      class="cl_table_det_text" 
                      wrapping="false"/>
            </uitable:template>
        </uitable:Column>

        <!-- Currency -->
        <uitable:Column hAlign="Center" width="5rem">
            <Text text="Currency" class="cl_Tltxt"/>
            <uitable:template>
                <Text text="{ItemsModel>Waers}" 
                      tooltip="{ItemsModel>Waers}" 
                      class="cl_table_det_text" 
                      wrapping="false"/>
            </uitable:template>
        </uitable:Column>
    </uitable:columns>
</uitable:Table>
