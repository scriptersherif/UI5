												<uitable:template class="cl_column_cell">
													<Text text="{MProfit>Belnr}" class="cl_table_det_text"/>
												</uitable:template>
											</uitable:Column>
											<!-- Doc. Type -->
											<uitable:Column width="120px" hAlign="Center" class="cl_column_header">
												<Text text="Doc. Type" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{MProfit>Blart}" class="cl_table_det_text"/>
												</uitable:template>
											</uitable:Column>
											<!-- Posting Date -->
											<uitable:Column width="120px" hAlign="Center" class="cl_column_header">
												<Text text="Posting Date" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{path:'MProfit>Reindat' , formatter :'FSC360NEW.model.formatter.fnDate'}" class="cl_table_det_text"/>
												</uitable:template>
											</uitable:Column>
											<!-- Vendor Code -->
											<uitable:Column width="120px" hAlign="Center" class="cl_column_header">
												<Text text="Vendor Code" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{MProfit>Lifnr}" class="cl_table_det_text"/>
												</uitable:template>
											</uitable:Column>
											<!-- Vendor Name -->
											<uitable:Column width="150px" hAlign="Center" class="cl_column_header">
												<Text text="Vendor Name" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{MProfit>Name1}" class="cl_table_det_text"/>
													<!--		<Image src="{path:'MProfit>Mindk' , formatter:'FSC360NEW.model.Formatter.MSME'}"-->
													<!--visible="{path:'MProfit>Mindk' , formatter:'FSC360NEW.model.Formatter.fnVisible'}" height="15px" width="30px"-->
													<!--class="sapUiMediumMarginBegin"></Image>-->
												</uitable:template>
											</uitable:Column>
											<!-- Invoice No. -->
											<uitable:Column width="130px" hAlign="Center" class="cl_column_header">
												<Text text="Invoice No." class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{MProfit>Xblnr}" class="cl_table_det_text"/>
												</uitable:template>
											</uitable:Column>
											<!-- Invoice Date -->
											<uitable:Column width="160px" hAlign="Center" class="cl_column_header">
												<Text text="Invoice Date" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{path:'MProfit>Bldat' , formatter :'FSC360NEW.model.formatter.fnDate'}" class="cl_table_det_text"/>
												</uitable:template>
											</uitable:Column>
											<!-- Amount -->
											<uitable:Column width="120px" hAlign="Center" class="cl_column_header">
												<Text text="Amount" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{MProfit>Dmbtr}" class="cl_table_det_text"/>
												</uitable:template>
											</uitable:Column>
											<!-- Due Date -->
											<uitable:Column width="100px" hAlign="Center" class="cl_column_header">
												<Text text="Due Date" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{path:'MProfit>Netdt' , formatter :'FSC360NEW.model.formatter.fnDate'}" class="cl_table_det_text"/>
												</uitable:template>
											</uitable:Column>
											<!-- Pay Amount -->
											<uitable:Column width="130px" hAlign="Center" class=" cl_column_header ">
												<Text text="Pay Amount" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Input value="{MProfit>PayAmount}" class="cl_textin " id="id_payamount"
														enabled="{path:'MProfit>Shkzg' , formatter :'FSC360NEW.model.formatter.fnEditable'}"
														editable="{= ${MProfit>/edit_amount} === 'true' ? true : false}"  submit="onPayAmountchange"></Input>
												</uitable:template>
											</uitable:Column>
											<uitable:Column width="120px" hAlign="Center" class="cl_column_header">
												<Text text="Partial Paid" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{MProfit>PartialPaid}" class="cl_table_det_text" tooltip="Partial paid"/>
												</uitable:template>
											</uitable:Column>
											<uitable:Column width="80px" hAlign="Center" class="cl_column_header">
												<Text text="Currency" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<Text text="{MProfit>Waers}" class="cl_table_det_text" tooltip="Currency"/>
												</uitable:template>
											</uitable:Column>
											<uitable:Column width="150px" hAlign="Center" class="cl_column_header">
												<Text text="Ageing" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<HBox alignContent="Center" alignItems="Center" justifyContent="Center" class="cl_toolheight">
														<Text text="{MProfit>Ageing}" class="cl_table_det_text" tooltip="Age"/>
														<!--<Image src="{path:'MProfit>Indi', formatter :'FSC360NEW.model.Formatter.Age'}" height="15px" width="15px" class="cl_agetextAlign"/>-->
													</HBox>
												</uitable:template>
											</uitable:Column>
											<uitable:Column width="100px" hAlign="Center" class="cl_column_header">
												<Text text="Credit/Debit" class="cl_Tltxt"/>
												<uitable:template class="cl_column_cell">
													<HBox alignItems="Center" width="90px">
														<Button id="statusBtn" text="{path:'MProfit>Shkzg', formatter:'FSC360NEW.model.formatter.CD'}" icon="sap-icon://circle-task-2"
															iconFirst="true" type="Transparent" class="cl_status">
															<customData>
																<core:CustomData key="status" value="{MProfit>Shkzg}" writeToDom="true"/>
															</customData>
														</Button>
													</HBox>
												</uitable:template>
											</uitable:Column>
										</uitable:columns>
									</uitable:Table>
								</VBox>
								<!--<HBox justifyContent="SpaceBetween" alignItems="Center" class="cl_pagination_footer cl_pagination_footer1">-->
								<!-- Left Slot: Previous Button -->
								<!--	<HBox width="100px" justifyContent="Start">-->
								<!--		<Button icon="Images/arrow-left.svg" text="Previous" id="previous" class="cl_prev_button" press="onPreviousPage" visible="true"/>-->
								<!--	</HBox>-->
								<!-- Center Slot: Page Numbers (Always Centered) -->
								<!--	<HBox width="calc(100% - 200px)" id="idPageNumbersBox" justifyContent="Center" alignItems="Center" class="cl_page_numbers">-->
								<!-- Page buttons dynamically inserted here -->
								<!--	</HBox>-->
								<!-- Right Slot: Next Button -->
								<!--	<HBox width="100px" justifyContent="End">-->
								<!--		<Button text="Next" icon="Images/arrow-right.svg" id="next" iconFirst="false" class="cl_next_button" press="onNextPage" visible="true"/>-->
								<!--	</HBox>-->
								<!--</HBox>-->
							</VBox>
						</VBox>
					</HBox>
				</content>
			</Page>
		</pages>
	</App>
</mvc:View>
