								<HBox width="100px" justifyContent="Start">
									<Button icon="Images/arrow-left.svg" text="{i18n>Previous}" tooltip="{i18n>Previous}" id="idPrevButton" class="cl_prev_button"
										press="fn_onPreviousPage" visible="true"/>
								</HBox>
								<!-- Dynamic Page Numbers -->
								<HBox width="calc(100% - 200px)" id="idPageNumbersBox" justifyContent="Center" alignItems="Center" class="cl_page_numbers">
