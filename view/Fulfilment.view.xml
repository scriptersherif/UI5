												<Text text="{pickModel>Name1}" class="cl_table_det_text"/>
											</uitable:template>
										</uitable:Column>
										<uitable:Column width="15%" hAlign="Center" class="cl_column_header">
											<Text text="Purchase Order" class="cl_Tltxt"/>
