								</HBox>
								<!-- Next Button -->
								<HBox width="100px" justifyContent="End">
									<Button text="{i18n>Next}" tooltip="{i18n>Next}" icon="Images/arrow-right.svg" id="idNextButton" iconFirst="false" class="cl_next_button"
										press="fn_onNextPage" visible="true"/>
								</HBox>
							</HBox>
							<HBox justifyContent="SpaceBetween" alignItems="Center" class="cl_pagination_footer" width="100%" id="fultabPick" visible="false">
								<!-- Previous Button -->
								<HBox width="100px" justifyContent="Start">
									<Button icon="Images/arrow-left.svg" text="{i18n>Previous}" tooltip="{i18n>Previous}" id="idPrevPickButton" class="cl_prev_button"
										press="fn_onPreviousPickPage"/>
								</HBox>
								<!-- Dynamic Page Numbers -->
								<HBox width="calc(100% - 200px)" id="idPickPageNumbersBox" justifyContent="Center" alignItems="Center" class="cl_page_numbers">
									<!-- Page number buttons will be created dynamically in controller -->
								</HBox>
								<!-- Next Button -->
								<HBox width="100px" justifyContent="End">
									<Button text="{i18n>Next}" tooltip="{i18n>Next}" icon="Images/arrow-right.svg" id="idNextPickButton" iconFirst="false"
										class="cl_next_button" press="fn_onNextPickPage"/>
								</HBox>
							</HBox>
						</VBox>
						<VBox class="cl_leftPanell1" height="100%" visible="{JsScrl>/0/Key}">
							<HBox alignItems="Center" justifyContent="SpaceBetween" class="cl_pdfHeader">
								<HBox alignItems="Center" gap="0.5rem">
									<Text text="View Invoice" class="cl_pdfTitle"/>
									<!--<Button icon="Images/plus.svg" tooltip="Zoom In" press="fn_onZoomIn" type="Transparent"-->
									<!--	class=" sapUiSizeCompact sapUiTinyMarginEnd cl_filter_btn " width="12px" height="12px"/>-->
									<!--<Button icon="Images/minus.svg" tooltip="Zoom Out" press="fn_onZoomOut" type="Transparent"-->
									<!--	class=" sapUiSizeCompact sapUiTinyMarginEnd cl_filter_btn"/>-->
									<Button icon="Images/print.svg" tooltip="Print" press="fn_onPrint" type="Transparent"
										class=" sapUiSizeCompact sapUiTinyMarginEnd cl_filter_btn"/>
									<Button icon="Images/downloadin.svg" tooltip="Download PDF" press="fn_onDownload" type="Transparent"
										class=" sapUiSizeCompact sapUiTinyMarginEnd cl_filter_btn"/>
								</HBox>
								<!--<Text text="View Invoice" class="cl_pdfTitle"/>-->
								<Image src="Images/window-close.svg" class="cl_pdfIconBtn" press="fn_close_pdf"/>
							</HBox>
							<VBox class="cl_leftPanell">
								<ScrollContainer id="id_scrll" width="100%" class="cl_pdfScroll" visible="{JsScrl>/0/Key}" focusable="true" horizontal="true"
									vertical="true"></ScrollContainer>
							</VBox>
						</VBox>
					</HBox>
				
				</content>
			</Page>
		</pages>
	</App>
