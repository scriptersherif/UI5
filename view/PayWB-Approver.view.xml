<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" controllerName="FSC360NEW.controller.PayWB-Approver"
	xmlns:html="http://www.w3.org/1999/xhtml" xmlns="sap.m" xmlns:f="sap.ui.layout.form.SimpleForm" xmlns:ui="sap.ui.table">
	<App>
		<pages>
			<Page class="cl_page">
				<customHeader>
					<Toolbar class="header_bar1 sapUiSmallMarginEnd">
						<Image id="id_fnback" src="Images/arrow-left.svg" class="cl_back_btn sapUiSmallMarginBegin" visible="false" press="fn_back"/>
						<Text text="Payment Workbench " class="cl_bold cl_black_txt cl_heading cl_font sapUiSmallMarginBegin"/>
							 <RadioButtonGroup id="idViewSelector" class="cl_RadiotxtBtn" columns="3" select="onRadioNav">
                    <buttons>
                         <RadioButton text="Initiator" class="cl_RadiotxtBtn"/>
                        <RadioButton text="Approver" class="cl_RadiotxtBtn"/>
                        <RadioButton text="Bank Approver" class="cl_RadiotxtBtn"/>
                    </buttons>
                </RadioButtonGroup>
						<ToolbarSpacer/>
						<Button icon="Images/refreshbtn.png" tooltip="Refresh" class="refresh_btn" press="fn_final"/>
						<Button icon="Images/bellbtn.png" tooltip="Notification" class="notifi_btn" press="fn_work"/>
						<HBox class="team_account" alignItems="Center" justifyContent="SpaceBetween">
							<Text text="" id="id_uname" class="cl_username cl_font team_text"/>
							<Image src="Images/Input.svg" class="team_image"/>
						</HBox>
					</Toolbar>
				</customHeader>
				<SplitApp id="SplitAppDemo" class="cl_payment_whole" initialMaster="master" initialDetail="detail">
					<detailPages>
						<Page id="detail" class="cl_detail_appr" title="Detail 1" width="100%" showHeader="false" backgroundDesign="Solid">
