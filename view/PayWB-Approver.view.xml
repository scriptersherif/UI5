												<Button icon="Images/file-document-white.svg" text="Print/ PDF" class="bluebtn bluebtnicon" press="onPressPDF" enabled="true" id="id_pdf"
													visible="false"></Button>
											</HBox>
										</HBox>
									</Toolbar>
									<VBox class="scrollContainer" id="id_vbox_table" width="100%">
										<ui:Table class="cl_payment_table cl_custom_table cl_custom_tableapk " visibleRowCount="5" id="id_table" rows="{MProfit>/}" width="100%"
											selectionMode="None">
											<ui:columns>
												<ui:Column width="20px">
													<Text text=""/>
													<!-- Empty column -->
													<ui:template>
														<Link text="{MProfit>Prctr1}" class="cl_qid_sel " wrapping="false"/>
														<!--<Text text="{MProfit>Prctr}" class="cl_Tltxt" tooltip="Profit Center"/>-->
													</ui:template>
												</ui:Column>
												<!-- Profit Center -->
												<ui:Column width="120px" hAlign="Center">
													<Text text="Profit Center" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{MProfit>Prctr}" class="cl_Tltxt" wrapping="false"/>
														<!--<Text text="{MProfit>Prctr}" class="cl_Tltxt" tooltip="Profit Center"/>-->
													</ui:template>
												</ui:Column>
												<!-- Doc No -->
												<ui:Column width="130px" hAlign="Center">
													<Text text="Doc No" class="cl_Tltxt"/>
													<ui:template>
														<Link text="{MProfit>Belnr}" class="cl_qid_sel " textAlign="Begin" tooltip="Document Number" press="fn_docdisplay"/>
													</ui:template>
												</ui:Column>
												<!-- Doc Type -->
												<ui:Column width="120px" hAlign="Center">
													<Text text="Doc Type" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{MProfit>Blart}" class="cl_Tltxt" textAlign="Begin" tooltip="Document Type"/>
													</ui:template>
												</ui:Column>
												<!-- Posting Date -->
												<ui:Column width="120px" hAlign="Center" class="cl_tab">
													<Text text="Posting Date" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{path:'MProfit>Reindat' , formatter :'FSC360NEW.model.formatter.fnDate'}" class="cl_Tltxt" tooltip="Date"/>
													</ui:template>
												</ui:Column>
												<!-- Vendor -->
												<ui:Column width="120px" hAlign="Center">
													<Text text="Vendor" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{MProfit>Lifnr}" class="cl_Tltxt" textAlign="Begin" tooltip="Vendor"/>
													</ui:template>
												</ui:Column>
												<!-- Vendor Name -->
												<ui:Column width="150px" hAlign="Center" class="cl_vtool">
													<Text text="Vendor Name" class="cl_Tltxt"/>
													<ui:template>
														<!--<Toolbar class="cl_tool cl_toolheight8">-->
															<Text text="{MProfit>Name1}" class="cl_Tltxt" textAlign="Begin" tooltip="Vendor Name"/>
														<!--	<ToolbarSpacer/>-->
														<!--</Toolbar>-->
													</ui:template>
												</ui:Column>
												<!-- Invoice -->
												<ui:Column width="130px" hAlign="Center">
													<Text text="Invoice" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{MProfit>Xblnr}" class="cl_Tltxt" textDirection="LTR" tooltip="Invoice"/>
													</ui:template>
												</ui:Column>
												<!-- Invoice Date -->
												<ui:Column width="160px" hAlign="Center">
													<Text text="Invoice Date" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{path:'MProfit>Bldat' , formatter :'FSC360NEW.model.formatter.fnDate'}" class="cl_Tltxt" tooltip="Invoice Date"/>
													</ui:template>
												</ui:Column>
												<!-- Amount -->
												<ui:Column width="120px" hAlign="Center">
													<Text text="Amount" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{MProfit>Dmbtr}" class="cl_Tltxt" textAlign="Right" textDirection="Inherit" tooltip="Amount"/>
													</ui:template>
												</ui:Column>
												<!-- Due Date -->
												<ui:Column width="100px" hAlign="Center">
													<Text text="Due Date" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{path:'MProfit>Netdt' , formatter :'FSC360NEW.model.formatter.fnDate'}" class="cl_Tltxt" textAlign="Right"
															textDirection="Inherit" tooltip="Due Date"/>
													</ui:template>
												</ui:Column>
												<!-- Pay Amount -->
												<ui:Column width="130px" hAlign="Center">
													<Text text="Pay Amount " class="cl_Tltxt"/>
													<ui:template>
														<Text text="{MProfit>PayAmount}" class="cl_Tltxt" textDirection="Inherit" tooltip="Pay Amount"/>
													</ui:template>
												</ui:Column>
												<!-- Partial Paid -->
												<ui:Column width="120px" hAlign="Center">
													<Text text="Partial Paid" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{MProfit>PartialPaid}" class="cl_Tltxt" textDirection="Inherit" tooltip="Partial paid"/>
													</ui:template>
												</ui:Column>
												<!-- Currency -->
												<ui:Column width="80px" hAlign="Center">
													<Text text="Currency" class="cl_Tltxt"/>
													<ui:template>
														<Text text="{MProfit>Waers}" class="cl_Tltxt" textDirection="LTR" tooltip="Currency"/>
													</ui:template>
												</ui:Column>
