														<Text text="{path:'MProfit>Shkzg', formatter:'FSC360NEW.model.formatter.CD'}" class="cl_Tltxt" id="id_cd" tooltip="S/H indicator"/>
													</ui:template>
												</ui:Column>
											</ui:columns>
