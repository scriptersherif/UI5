											<HBox >
												<Text text="Open Item" class="cl_scan_text cl_open_text sapUiSmallMarginBegin "/>
												<!--<HBox class="cl_badge_counter_2">-->
												<Text text="" id="id_selected" class="cl_badge_counter_appr"></Text>
												<!--</HBox>-->
												<Text text="Total Amount" class="sapUiTinyMarginBegin greybox"/>
												<Text id="id_totamt" text="RS. 1000" class=" greenbox"/>
											</HBox>
											<!-- Spacer pushes next items further right -->
											<!-- Search Field -->
											<HBox alignItems="Center" class="sapUiTinyMarginEnd">
												<HBox class="cl_hbx_sf cl_hbx_sf1">
													<Button icon="sap-icon://navigation-down-arrow" class="cl_arrow sapUiSizeCompact sapUiTinyMarginBegin" press="fnSearchPop"></Button>
													<SearchField placeholder="Search" id="id_search2" class="cl_search_pay_appr sapUiTinyMarginTop sapUiSizeCompact " liveChange="fnSearchField"
														search="fnSearchField"></SearchField>
												</HBox>
												<!-- Comments Button -->
												<Button text="Comments" class="sapUiSizeCompact sapUiTinyMarginEnd greybtn" icon="Images/comment-text-multiple-outline.svg"
