<?xml version="1.0" encoding="UTF-8"?>
<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Dialog title="Enter PO" class="sapUiSizeCompact ">
    <content>
      <!--<Input id="InGrn" class="sapUiSmallMarginBegin sapUiSmallMarginEnd" maxLength="14" width="90%"/>-->
      <List items="{JSSesDet>/}" width="100%">
        <CustomListItem width="100%">
                  <!--  <HBox width="100%">-->
          <Input id="InGrn" maxLength="10" value="{JSSesDet>Ebeln}" liveChange="fnTypeNumber" width="75%" class="InputPlaceholder_CP InputPlaceholder_CPD sapUiSmallMarginBegin"></Input>
          <Image id="id_AddImg" src="Images/Plus.png" height="1.8rem" visible = "true" class="sapUiTinyMarginBegin" press="fnPressAddPO"></Image>
          <Image id="id_RemoveImg" src="Images/minus.png" height="1.8rem" visible = "true" class="sapUiTinyMarginBegin" press="fnPressDeletePO"></Image>
                  <!--  </HBox>-->
        </CustomListItem>
      </List>
      <OverflowToolbar class="barClass sapUiTinyMarginTop">
        <Button type="Reject" text="{i18n>cancel}" icon="sap-icon://decline" press="fnGrnClose" tooltip="{i18n>cancel}"/>
        <ToolbarSpacer/>
        <Button type="Accept" icon="sap-icon://accept" text="{i18n>Submit}" press="fnSubmitGRN" tooltip="{i18n>Submit}"/>
      </OverflowToolbar>
    </content>
  </Dialog>
</core:FragmentDefinition>