<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Popover showHeader="false" placement="Bottom" id="idTemplatePopover" class="clcustomizetemppop">
    <VBox>
      <!--<List id="idTemplateList" items="{viewModel>/templates}">-->
      	<List id="idTemplateList" items="{viewModel>/templates}" 
      itemPress="onTemplateListItemPress" mode="SingleSelectMaster" selectionChange="onTemplateSelectionChange">
        <CustomListItem>
          <HBox justifyContent="SpaceBetween" width="100%" class="templateListItemBox">
            <Text text="{viewModel>name}" />
            <Button icon="sap-icon://delete" press="onDeleteTemplate" type="Transparent"/>
          </HBox>
        </CustomListItem>
      </List>
      <!--<Button icon="sap-icon://add" text="Create Template" type="Transparent" press="onOpenCreateTemplateDialog"  class="fullWidthTemplateButton"/>-->
   <HBox justifyContent="SpaceBetween" width="100%" class="templateListItemBox">
            <Text text="Create Template" />
            <Button icon="sap-icon://add" press="onOpenCreateTemplateDialog" type="Transparent"/>
          </HBox>
    </VBox>
  </Popover>
</core:FragmentDefinition>