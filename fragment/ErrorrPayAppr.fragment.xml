<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<Dialog id="errorDialog" showHeader="false" class="cl_successDialog cl_rejpopup" stretchOnPhone="true" draggable="false" resizable="false">
		<VBox class="cl_invublsuccess"  width="100%" alignItems="Center" justifyContent="Start">
			<VBox class="cl_warningTopCurve1" alignItems="Center" justifyContent="Center">
				<Image src="Images/errorinv.svg" class="cl_successIcon"/>
			</VBox>
			<VBox class="cl_errorContent1" alignItems="Center" justifyContent="Center">
				<Text text="" id="id_error_text" class="cl_successTitle"/>
				
			</VBox>
			<HBox class="cl_errorFooter"  width="100%" alignItems="Center" justifyContent="Center">
				<Button text="✕ Close" class="cl_btn_searchapp cl_btn_searchsuccess" press="fn_onCloseErrorDialog"/>
			</HBox>
		</VBox>
	</Dialog>
</core:FragmentDefinition>