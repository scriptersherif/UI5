<core:FragmentDefinition xmlns="sap.m" xmlns:ui="sap.ui.table" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:t="sap.ui.table">
	<Dialog id="idViewDetailsDialog" showHeader="false" title="{i18n>viewDetailsDialogTitle}"
		class="cl_frag_rightslidesum cl_frag_rightslide_view" resizable="true" draggable="false" contentHeight="auto"
		afterOpen="onAfterSimulateDialogOpen">
		<HBox justifyContent="SpaceBetween" alignItems="Center" class="cl_pdf_dialog_header cl_view_dialog_header">
			<Text text="{i18n>viewDetailsHeader}" class="sapUiTinyMargin sapMTitle cl_dialog_text"/>
			<Button icon="Images/cancel.svg" type="Transparent" class="cl_view_close" press="fn_fragViewClose" tooltip="{i18n>closeButtonTooltip}"/>
		</HBox>
		<ScrollContainer height="100%" width="100%" vertical="true">
			<t:Table id="idViewDetailsTable" columnHeaderVisible="false" rowHeaderVisible="false" selectionMode="None" visibleRowCount="16"
				class="sapUiSmallMarginBegin sapUiSmallMarginTopBottom cl_view_table"/>
		</ScrollContainer>
	</Dialog>
</core:FragmentDefinition>