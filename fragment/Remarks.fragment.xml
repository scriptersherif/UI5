<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<Dialog id="id_dialogremarks" title="Remarks" icon="sap-icon://message" class="cl_agentDialog"
		afterClose=".onRemarkDialogClose">
		<VBox class="cl_tool" height="8rem">
				<!--<Text text="Remarks" class="cl_bar_text" id="Remarks"/>-->
				<TextArea id="textAreaWithBinding2" placeholder="Enter here..."  class="cl_remarksInput customTextArea" maxLength="50"
					width="100%" height="50%" 	liveChange="fnLiveRemark"/>
			</VBox>
	
		<beginButton>
			<Button text="Cancel" id="id_reject1" icon="Images/cancel.svg" press="fn_closeremarks" class="cl_canbtn gl_canbtn gl_canbtn1 "/>
		</beginButton>
		<endButton>
			<Button text="Submit" id="id_approve" icon="Images/approve_image.svg" press="fn_okremarks" class=" gl_subbtn gl_subbtn1 "/>
		</endButton>
	</Dialog>
</core:FragmentDefinition>