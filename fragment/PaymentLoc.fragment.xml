<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
 <SelectDialog
        noDataText="No Records Found"
        title="Payment Location"     
        confirm="onSelectPaymentLoc"
        cancel="oncancelbusiness"
        liveChange="handleSearchPaymentLocation"
        items="{MPaymentLoc>/}" >
        <StandardListItem
            title="{MPaymentLoc>ZsapValue}"
            description="{}"
            iconDensityAware="false"
            iconInset="false"
            type="Active" />
    </SelectDialog>
</core:FragmentDefinition>