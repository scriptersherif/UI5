<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<Popover title="Create New Template" placement="Bottom" class="sapUiContentPadding clcustomizecreatetemppop"
		id="idCreateTemplatePopoverfullfill">
		<VBox class="customcol_padding">
			<Label text="Template Name" class="popup_subheading"/>
			<Input id="idNewTemplateName_ful" placeholder="Enter name" class="templateSelectWrapper"/>
				<HBox alignItems="Center" class=" customCheckWrapper sapUiTinyMarginBegin sapUiTinyMarginBottom">
        <CheckBox 
                  text="Select All"
                  select="fn_onSelectAll" />
                   <Text text="Select All"  class="sapUiTinyMarginEnd  popuptext" />
      </HBox>
			<List id="idNewFieldList" items="{FilterTableModel>/}" class="noListBorder">
				<CustomListItem>
					<HBox alignItems="Center" class="clListItemStyled customCheckWrapper">
						<Image src="Images/dots-drag.svg" class=""/>
						<CheckBox selected="{FilterTableModel>visible}" width="100%"/>
						<Text text="{FilterTableModel>label}" class="sapUiTinyMarginEnd popuptext"/>
					</HBox>
				</CustomListItem>
			</List>
		
			
			</VBox>
			   <footer>
      <Bar design="Footer" class="grey_background">
        <contentRight>
          <Button text="{i18n>Cancel}" 
                  type="Transparent" 
                  class="whitebtn bluebtnfragment"
                  press="fn_onCancelCreateTemplate"/>
          <Button text="Save" 
                  type="Emphasized" 
                  class="bluebtn bluebtnfragment bluebtngap"
                  press="fn_onSaveNewTemplate"/>
        </contentRight>
      </Bar>
    </footer>
		</Popover>
	</core:FragmentDefinition>