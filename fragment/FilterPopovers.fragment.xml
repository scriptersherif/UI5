<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<Popover class="sapUiContentPadding SettingsPOPCls cl_popadapk" placement="Bottom" showHeader="false" modal="false">
		<content >
			<VBox alignItems="Start" justifyContent="Start" alignContent="Center">
				
				
				<Button icon="Images/custom.svg" iconFirst="true"  text="{i18n>Customize Columns}" press="fncustomcolumns"
					class=" sapUiSizeCompact cl_query cl_adfrag_btn "></Button>
			
			
				<Button  icon="Images/wrap.svg" press="fnToggleWrapText" iconFirst="true"
					text="{i18n>Wrap Text}" class=" sapUiSizeCompact cl_comment cl_adfrag_btn "></Button>
			
			</VBox>
		</content>
	</Popover>
</core:FragmentDefinition>