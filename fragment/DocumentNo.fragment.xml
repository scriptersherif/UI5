<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" id="id_docFrag">
	<Dialog id="id_dialogdoc" title="Enter Document No" class="cl_dialogtitle">
		<VBox width="400px">
			<Toolbar class="cl_tool">
				<Text text="Documnet No" class="sapUiTinyMargin"/>
				<ToolbarSpacer></ToolbarSpacer>
				<MultiInput showValueHelp="false" id="id_docnofrag"
					class="cl_inputbox cl_multi cl_multi2 cl_multi3 sapUiSizeCompact sapUiTinyMarginTop sapUiTinyMarginEnd sapUiTinyMarginBegin"
					showSuggestion="false" width="96%" tokens="{JMDoc>/items}">
					<tokens>
						<Token text="{JMDoc>text}"/>
					</tokens>
				</MultiInput>
			</Toolbar>
			<Toolbar class="cl_tool">
				<Text text="Fiscal Year" class="sapUiTinyMargin"/>
				<ToolbarSpacer></ToolbarSpacer>
				<DatePicker id="id_doc_year" change="handleChange" class="cl_inputbox_doc cl_icon sapUiSizeCompact sapUiTinyMarginEnd sapUiTinyMarginTop" width="18.5rem"
					value="{ 'path': '/valueDP11', 'type': 'sap.ui.model.type.Date', 'formatOptions': { 'pattern': 'yyyy' } }" valueFormat="yyyy" displayFormat="yyyy"/>
			</Toolbar>
			<HBox alignContent="Center" alignItems="Center" justifyContent="Center">
				<Label text="Document No Entered" class="sapUiTinyMarginBegin" labelFor="id_invnofrag"/>
			</HBox>
			<List width="100%" items="{JMDoc>/items}">
				<StandardListItem title="{JMDoc>text}"/>
			</List>
		</VBox>
		<HBox alignContent="Center" alignItems="Center" justifyContent="Center">
			<Button text="Ok" press="fn_close_doc" class="cl_btnsubmit3"></Button>
			<Button text="Cancel" press="fn_clear_doc" class="sapUiMediumMarginBegin cl_btnsubmit3"></Button>
		</HBox>
	</Dialog>
</core:FragmentDefinition>