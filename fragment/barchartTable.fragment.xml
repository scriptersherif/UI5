<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    
    xmlns:T="sap.ui.table" xmlns:ui="sap.ui.table.Table"
 >

    <Dialog
        id="barChartDialog"
        draggable="true"
        resizable="true"
        showHeader="false"
        contentWidth="50rem"
        contentHeight="400px"       
        verticalScrolling="true"
        class="cl_agentDialog">

        <!-- Fixed top header -->
        <customHeader>
            <Toolbar class="cl_dialog" width="100%">
                <ToolbarSpacer/>
                <Text class="cl_dialoghd" text="Manual Postal Invoice Report"/>
                <ToolbarSpacer/>
                <Image
                    src="Images/xmark.svg"
                    width="20px"
                    class="sapUiSmallMargin"
                    press="fnCloseManualInvInfo"/>
            </Toolbar>
        </customHeader>

        <!-- Scrollable content (only table scrolls) -->
        <content>
            <VBox height="100%" justifyContent="Start">
                <ScrollContainer
                    height="100%"
                    vertical="true"
                    horizontal="false">

                    <Table
                        items="{barModel>/}"
                        width="100%"
                        class="sapUiSizeCompact cl_table1"
                        growing="true"
                        growingScrollToLoad="true"
                        growingThreshold="700"
                        fixedLayout="false">

                        <columns>
                            <Column>
                                <Text text="Invoice Document" class="cl_table-text1 cl_bold"/>
                            </Column>
                            <Column>
                                <Text text="Year" class="cl_table-text1 cl_bold"/>
                            </Column>
                            <Column>
                                <Text text="Account Document" class="cl_table-text1 cl_bold"/>
                            </Column>
                            <Column>
                                <Text text="Vendor" class="cl_table-text1 cl_bold"/>
                            </Column>
                            <Column>
                                <Text text="Invoice Type" class="cl_table-text1 cl_bold"/>
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{barModel>MIRO_DOC}"/>
                                    <Text text="{barModel>GJAHR}"/>
                                    <Text text="{barModel>ACCT_DOC}"/>
                                    <Text text="{barModel>NAME1}"/>
                                    <Text text="{barModel>INV_TYPE}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
