<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<Dialog id="errorDialog" showHeader="false" class="cl_successDialog cl_rejpopup" stretchOnPhone="true" draggable="false" resizable="false">
		<VBox class="cl_invublsuccess" alignItems="Center" justifyContent="Start">
			<VBox class="cl_warningTopCurve1" alignItems="Center" justifyContent="Center">
				<Image src="Images/errorinv.svg" class="cl_successIcon"/>
			</VBox>
			<VBox class="cl_errorContent1" alignItems="Center" justifyContent="Center">
				<Text text="Invoice Unblock Error" class="cl_successTitle"/>
				<ScrollContainer height="210px" id="id_list_invdet" vertical="true" class="gl_account_card_cont gl_account_card_cont_inv">
					<List items="{errorModel>/}" class="cl_rejpopup" growing="true" growingThreshold="5" growingScrollToLoad="true">
						<CustomListItem height="330px">
							<Text text="{errorModel>message}" class="cl_successMessage"/>
						</CustomListItem>
					</List>
				</ScrollContainer>
			</VBox>
			<HBox class="cl_errorFooter" alignItems="Center" justifyContent="Center">
				<Button text="✕ Close" class="cl_btn_searchapp cl_btn_searchsuccess" press="fn_onCloseErrorDialog"/>
			</HBox>
		</VBox>
	</Dialog>
</core:FragmentDefinition>