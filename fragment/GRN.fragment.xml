<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<Dialog title="{i18n>GRN}" class="sapUiSizeCompact APW_DilogClass">
		<content>
			<Input id="InGrn" maxLength="10" class="sapUiSmallMarginBegin sapUiSmallMarginEnd" width="90%"/>
			<OverflowToolbar class="barClass sapUiTinyMarginTop">
				<Button type="Reject" text="{i18n>cancel}" icon="sap-icon://decline" press="fnGrnClose" tooltip="{i18n>cancel}"/>
				<ToolbarSpacer/>
				<Button type="Accept" icon="sap-icon://accept" text="{i18n>Submit}" press="fnSubmitGRN" tooltip="{i18n>Submit}"/>
			</OverflowToolbar>
		</content>
	</Dialog>
</core:FragmentDefinition>