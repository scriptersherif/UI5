<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	
	 <SelectDialog
		    title="Purchase Order"
		    contentWidth="3rem"
		    class="sapUiPopupWithPadding"
		    search="fnFilterPO"
		    confirm="fnValueHelpCloseFrom"
		    cancel="fnValueHelpCloseFrom"
		    liveChange="fnFilterPO"
		    items="{P>/Podet/results}">
            <StandardListItem
		      iconDensityAware="false"
		      iconInset="false"
		      title="{P>Ebeln}"/>
  </SelectDialog>
</core:FragmentDefinition>