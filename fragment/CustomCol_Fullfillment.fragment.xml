<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Popover title="Customize Columns" placement="Bottom" class="sapUiContentPadding clcustomizepop">
    <VBox class="customcol_padding">
      <Label text="Choose Template" class="popup_subheading"/>
      <HBox  class="templateSelectWrapper"  alignItems="Center" >
        <Input id="idTemplateInput_fullfill" value="{viewModel>/selectedTemplate}" 
        placeholder="Select Template" showValueHelp="false" class="templateInputDropdown"/>
        <Button icon="Images/chevron-down.svg" press="fn_onOpenTemplatePopover" class="templateDropdownArrow"/>
      </HBox>


     <List
  id="idFieldListfullfill"
  items="{
    path: 'FilterTableModel>/',
    templateShareable: false
  }"
  showSeparators="None"
  mode="None">
  <CustomListItem>
    <HBox alignItems="Center" class="clListItemStyled customCheckWrapper">
    		<Image src="Images/dots-drag.svg" class="dots-drag"/>
      <!--<Icon src="Images/popup.svg" size="1rem" class="sapUiTinyMarginEnd"/>-->
            <CheckBox
        selected="{FilterTableModel>visible}"
       
        width="100%" class=""/>
      <Text text="{FilterTableModel>label}"  class="sapUiTinyMarginEnd popuptext" />
      
    </HBox>
  </CustomListItem>
</List>
      <!--<HBox justifyContent="SpaceBetween" class="sapUiSmallMarginTop">-->
      
      <!--  <Button text="Apply" type="Emphasized" press="fn_onApplyTemplate" />-->
      <!--</HBox>-->
    </VBox>
     <footer>
      <Bar design="Footer" class="grey_background">
        <contentRight>
          <Button text="Apply"
                  type="Emphasized"
                  class="bluebtn bluebtnfragment"
                  press="fn_onApplyTemplate" />
        </contentRight>
      </Bar>
    </footer>
  </Popover>
</core:FragmentDefinition>