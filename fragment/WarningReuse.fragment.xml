<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc">
	<Dialog id="warningDialog" showHeader="false" class="cl_successDialog" stretchOnPhone="true" draggable="false" resizable="false">
		<VBox class="cl_invublwarn" width="100%" alignItems="Center" justifyContent="Start">
			
			<!-- Top Section with Success Icon -->
			<VBox class="cl_warnTopCurve" alignItems="Center" justifyContent="Center">
				<Image src="Images/warning.svg" class="cl_successIcon"/>
			</VBox>

			<!-- Dynamic Message -->
			<VBox class="cl_successContent" alignItems="Center" justifyContent="Center">
				<Text text="{warnModel>/message}" class="cl_successTitle_medium" id="id_dynamicwarntest"/>
			</VBox>

			<!-- Footer with Close Button -->
			<HBox class="cl_errorFooter" width="100%" alignItems="Center" justifyContent="Center">
				<Button text="✕ Close " type="Emphasized" class="cl_btn_searchapp cl_btn_searchsuccess" press="fn_closewarn"/>
			</HBox>
		</VBox>
	</Dialog>
</core:FragmentDefinition>