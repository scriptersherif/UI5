<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:u="sap.ui.unified">
	<Dialog showHeader="true" title="Remarks" class="cl_agentDialog" id="id_dialog"  width="200px">
		<VBox class="sapUiTinyMargin"  >
			<VBox class="cl_tool sapUiSmallMarginEnd" id="toolid">
				<Text text="{i18n>PaymentLocation}" class="cl_bar_text" id="id_pl" visible="false"></Text>
				<Input class="cl_inputbox_payloc sapUiSizeCompact sapUiTinyMargin cl_glbox " width="70%" showValueHelp="true" valueHelpRequest="onValueHelpRequestPaymentLoc"
					id="id_payloc" showSuggestion="true" suggest="handleSuggestPayment" visible="false" suggestionItems="{MPaymentLoc>/}">
					<suggestionItems>
						<core:ListItem key="{MPaymentLoc>ZsapValue}" text="{MPaymentLoc>ZsapValue}"/>
					</suggestionItems>
				</Input>
			</VBox>
			<VBox class="cl_tool" height="8rem">
				<Text text="Remarks" class="cl_bar_text" id="Remarks"/>
				<TextArea id="textAreaWithBinding2"  class="cl_remarksInput customTextArea" maxLength="50"
					width="100%" height="50%"/>
			</VBox>
			<!--<HBox alignContent="Center" alignItems="Center" justifyContent="Center" class="sapUiSmallMargin">-->
			<!--	<Button text="Close" class="sapUiSizeCompact sapUiSmallMarginBeginEnd cl_reject" icon="sap-icon://decline" id="id_reject"-->
			<!--		press="fn_closeremarks"></Button>-->
			<!--	<Button text="Ok" class="sapUiSizeCompact cl_approve" icon="sap-icon://accept" id="id_approve" press="fn_okremarks"></Button>-->
			<!--</HBox>-->
		</VBox>
		<beginButton>
            <Button
                text="Close"    icon="Images/cancel.svg"
                 press="fn_closeremarks"  class="cl_canbtn gl_canbtn gl_canbtn1 " id="id_reject" />
        </beginButton>

        <endButton>
            <Button
               text="Ok" id="id_approve" icon="Images/approve_image.svg"
               press="fn_okremarks" class=" gl_subbtn gl_subbtn1 " />
        </endButton>
	</Dialog>
</core:FragmentDefinition>