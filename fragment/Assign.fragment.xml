<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc">
	<Dialog title="Agent Assignment" class="cl_agentDialog">
		<!--<HBox class="sapUiTinyMarginTop" alignContent="Center">-->
		<!--    <Text text="{i18n>Agent}" class="sapUiMediumMarginBegin sapUiTinyMarginTop"></Text>-->
		<!--    <Input  id="id_agent" maxLength="10" showValueHelp="true" valueHelpRequest="fn_Userfrag" class="sapUiSizeCompact sapUiSmallMarginBegin" liveChange="fn_Live"-->
		<!--    ></Input>-->
		<!--</HBox> gl_canbtn-->
		<VBox class="column formField sapUiSmallMarginBottom" >
			<Text text="{i18n>Agent}" class="cl_dialogLabel"></Text>
			<HBox class="">
				<!--<Input id="id_agent" maxLength="10" class="formInputA1"/>-->
				<!--<Image src="Images/popup.svg" width="16px" height="28px" press="fn_Userfrag" liveChange="fn_Live" class="inputIconA1"/>-->
			    <ComboBox
                id="id_agent"
                placeholder="{i18n>SelectAgent}"
                items="{
                    path: 'jsUserName>/'
                }"
                showSecondaryValues="true"
                selectionChange="fn_onAgentSelect"
                class="formInputA2 sapUiSmallMarginBegin"
                width="100%">

                <core:ListItem
                    key="{jsUserName>Bname}"
                    text="{jsUserName>Bname}" additionalText="{jsUserName>NameLast}"
                    />

            </ComboBox>
			</HBox>
		</VBox>
		<beginButton>
			<Button text="{i18n>Cancel}"  icon="Images/cancel.svg" class="cl_btn_deletec" press="fn_Assign_cancel"></Button>
		</beginButton>
		<endButton>
			<Button text="{i18n>Submit}" icon="Images/sub.svg" class=" gl_subbtn " press="fn_agent_submit"></Button>
		</endButton>
	</Dialog>
</core:FragmentDefinition>