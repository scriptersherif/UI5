<core:FragmentDefinition xmlns="sap.m" xmlns:ui="sap.ui.table" xmlns:core="sap.ui.core">
	<Dialog title="{i18n>Analysis}" showHeader="true" class="sapUiSizeCompact cl_frag" resizable="true"
		draggable="true">
		<content>
			<List items="{JMCONSucc>/}" id="id_consuccMSG" class="sapUiTinyMarginTop sapUiSizeCompact">
				<items>
					<CustomListItem type="Active" class="APW_MasterListClass">
						<Toolbar class="cl_toolBar">
							<Text text="{JMCONSucc>Message}" wrapping="false" class="sapUiSmallMarginBegin APW_SuccessMsgTxt"/>
							<ToolbarSpacer></ToolbarSpacer>
						</Toolbar>
					</CustomListItem>
				</items>
			</List>
			<List items="{JMCONError>/}" id="id_conerrMSG" class="sapUiTinyMarginTop sapUiSizeCompact">
				<items>
					<CustomListItem type="Active" class=" APW_MasterListClass">
						<Toolbar class="cl_toolBar">
							<Text text="{JMCONError>Message}" wrapping="false" class="sapUiSmallMarginBegin APW_ErrorMsgTxt"/>
							<ToolbarSpacer></ToolbarSpacer>
						</Toolbar>
					</CustomListItem>
				</items>
			</List>
		</content>
		<endButton>
			<Button text="{i18n>Close}" class="APW_CloseErrorBtn" press="fn_Confirmation_frag_close" tooltip="{i18n>Close}"/>
		</endButton>
		<!--<HBox class="sapUiSizeCompact sapUiSmallMargin" alignContent="Cneter" alignItems="Center" justifyContent="Center">-->
		<!--	<Button text="{i18n>Cancel}" press="fn_Confirmation_frag_close" class="sapUiTinyMarginEnd cl_fragcancelbtn" tooltip="{i18n>Cancel}"/>-->
		<!--</HBox>-->
	</Dialog>
</core:FragmentDefinition>