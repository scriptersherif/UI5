  		<Dialog id="id_payblock_dialog" title="Payment Blocked Invoices" draggable="true" resizable="true" contentWidth="50rem" showHeader="false">
		<Toolbar class="cl_dialog" width="100%">
			<ToolbarSpacer/>
			<Text class="cl_dialoghd" text="Payment Blocked Invoices"/>
			<ToolbarSpacer/>
			<Image src="Images/xmark.svg" width="20px" class="sapUiSmallMargin" press="onClosePayBlockDialog"/>
		</Toolbar> 

    <content>
      <Panel class="cl_panel">
     <ui:Table id="idUiPayBlockTable"
          rows="{payBlockModel>/items}"
          selectionMode="None"
          visibleRowCount="4"
          visibleRowCountMode="Fixed"
          width="100%"
          class="cl_payblocktab cl_tble cl_custom_table cl_tblepay"
          columnHeaderVisible="true">

  <ui:columns>
    <!-- 1. Queue Id -->
    <ui:Column width="6.3rem">
      <Label text="Queue Id" />
      <ui:template>
        <Text text="{payBlockModel>Qid}" class="cl_paytabtext" />
      </ui:template>
    </ui:Column>

    <!-- 2. Document No (Invoice Document) -->
    <ui:Column width="6rem">
      <Label text="Document No" />
      <ui:template>
        <Text text="{payBlockModel>Documentnumber}" class="cl_paytabtext" />
      </ui:template>
    </ui:Column>

    <!-- 3. Year -->
    <ui:Column width="3.5rem">
      <Label text="Year" />
      <ui:template>
        <Text text="{payBlockModel>Gjahr}" class="cl_paytabtext"/>
      </ui:template>
    </ui:Column>

    <!-- 4. BELNR (Accounting Document) -->
    <ui:Column width="6rem">
      <Label text="Acc Doc.no" />
      <ui:template>
        <Text text="{payBlockModel>Belnr}" class="cl_paytabtext"/>
      </ui:template>
    </ui:Column>

    <!-- 5. Vendor -->
    <ui:Column width="10rem">
      <Label text="Vendor" />
      <ui:template>
        <Text text="{payBlockModel>Name}" class="cl_paytabtext"/>
      </ui:template>
    </ui:Column>

    <!-- 6. Payment Term -->
    <ui:Column width="7rem">
      <Label text="Payment Term" />
      <ui:template>
        <Text text="{payBlockModel>Zterm}" class="cl_paytabtext"/>
      </ui:template>
    </ui:Column>

    <!-- 7. Status -->
    <ui:Column width="10rem">
      <Label text="Status" />
      <ui:template>
        <Text text="{payBlockModel>StatusText}" class="cl_paytabtext" />
      </ui:template>
    </ui:Column>
  </ui:columns>
</ui:Table>
         <HBox justifyContent="End" class="sapUiSmallMarginTop sapUiSmallMarginEnd">
    <Button text="Download Excel"
           
            icon="sap-icon://excel-attachment"
            press="onDownloadPayBlockExcel"
           class=" gl_subbtn sapUiSmallMarginBottom rignt "/>
  </HBox>
      </Panel>
    </content>

