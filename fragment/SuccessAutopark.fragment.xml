<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc">
    <Dialog id="successDialog"
            showHeader="false"
            class="cl_successDialog"
            stretchOnPhone="true"
            draggable="false"
            resizable="false">
        
        <VBox class="cl_invublsuccess" alignItems="Center" justifyContent="Start">
            <VBox class="cl_successTopCurve" alignItems="Center" justifyContent="Center">
                <Image src="images/rocket.svg" class="cl_successIcon" />
            </VBox>
            
            <VBox class="cl_successContent" alignItems="Center" justifyContent="Center">
                <Text text="Queids Posted Successfully" class="cl_successTitle" />
                <Text id="id_successText_apk" class="cl_successMessage" />
                <Button text="✕    Close " type="Emphasized"
                        class="cl_btn_searchapp cl_btn_searchsuccess "
                        press="fn_closeSuccess" />
            </VBox>
        </VBox>

    </Dialog>
</core:FragmentDefinition>