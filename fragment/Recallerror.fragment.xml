<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog id="errorDialog"
            showHeader="false"
            class="cl_successDialog"
            stretchOnPhone="true"
            draggable="false"
            resizable="false">
        
        <VBox class="cl_successWrapper" alignItems="Center" justifyContent="Start">
            <VBox class="cl_errorTopCurve" alignItems="Center" justifyContent="Center">
                <Image src="Images/error.svg" class="cl_successIcon" />
            </VBox>
            
            <VBox class="cl_errorContent" alignItems="Center" justifyContent="Center">
                <Text text="Recall Failed" class="cl_successTitle" />
                <Text text="{errorModel>/message}" class="cl_successMessage" />
           <!--<Button text="✕ Close" type="Reject"-->
           <!--             class="cl_btn_searchapp cl_btn_searchsuccess"-->
           <!--             press=".onCloseErrorDialog" />-->
            </VBox>
                 <HBox class="cl_errorFooter" alignItems="Center" justifyContent="Center">
            <Button text="✕ Close"
                    
                    class="cl_btn_searchapp cl_btn_searchsuccess"
                    press="onCloseErrorDialog" />
        </HBox>   
        </VBox>
   
       
    </Dialog>
</core:FragmentDefinition>